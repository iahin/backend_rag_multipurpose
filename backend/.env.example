APP_NAME=backend-rag-multipurpose
APP_HOST=0.0.0.0
APP_PORT=9010
HOST_APP_PORT=9010
LOG_LEVEL=INFO

POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/ragdb
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_POOL_SIZE=10

REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=rag_chunks

OPENAI_API_KEY=

NIM_API_KEY=

GEMINI_API_KEY=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HEALTH_TIMEOUT_SECONDS=3.0

RERANK_ENABLED=false
RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
RERANK_MAX_CANDIDATES=12
RERANK_MIN_CANDIDATES=2

DEFAULT_LLM_PROFILE=ollama_llama32
GENERATION_PROFILES={"nim_3super120":{"provider":"nim","model":"nvidia/nemotron-3-super-120b-a12b"},"openai_gpt41_mini":{"provider":"openai","model":"gpt-4.1-mini"},"ollama_llama32":{"provider":"ollama","model":"llama3.2"}}
DEFAULT_EMBEDDING_PROFILE=ollama_1536
EMBEDDING_PROFILES={"ollama_1536":{"provider":"ollama","model":"rjmalagon/gte-qwen2-1.5b-instruct-embed-f16","dimension":1536},"openai_small_1536":{"provider":"openai","model":"text-embedding-3-small","dimension":1536},"ollama_4096":{"provider":"ollama","model":"qwen3-embedding","dimension":4096},"nim_nemotron_2048":{"provider":"nim","model":"nvidia/llama-nemotron-embed-1b-v2","dimension":2048}}

RETRIEVAL_CACHE_TTL_SECONDS=120
AUTH_ENABLED=true
AUTH_JWT_SECRET=change-me-immediately
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-me-immediately
AUTH_REQUIRE_HTTPS=false
CHAT_TEMPERATURE=0.0
CHAT_THINKING_ENABLED=false
CHAT_SHOW_THINKING_BLOCK=false
